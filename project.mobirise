                "transition": "none",
                "margin": "0 !important"
              }
            },
            ".navbar": {
              "min-height": "122px",
              "transition": "all 0.3s",
              "border-bottom": "1px solid transparent",
              "&:not(.navbar-short)": {
                "border-bottom": "none"
