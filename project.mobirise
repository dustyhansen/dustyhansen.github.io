          "_name": "afeatures11",
          "_sourceTheme": "expertm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features11 expertm5\" group=\"Features\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <select title=\"Align\" name=\"contentAlign\">\n            <option value=\"justify-content-start\" selected>Left</option>\n            <option value=\"justify-content-center\">Center</option>\n            <option value=\"justify-content-end\">Right</option>\n        </select>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showMainTitle\">\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showMainSubtitle\">\n        <input type=\"checkbox\" title=\"Lines Title\" name=\"showCardsTitle\">\n        <input type=\"checkbox\" title=\"Lines Subtitle\" name=\"showCardsSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Lines Text\" name=\"showLinesText\" checked>\n        <input type=\"range\" inline title=\"List Count\" name=\"listCount\" min=\"1\" max=\"2\" step=\"1\" value=\"2\">\n        <select title=\"Lines 1\" name=\"cardsAmount1\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\" selected>5</option>\n        </select>\n        <select title=\"Lines 2\" name=\"cardsAmount2\" condition=\"listCount >1\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\" selected>5</option>\n        </select>\n        <header>Lines 1</header>\n        <input type=\"range\" inline title=\"Line Active 1\" name=\"line1Active1\" min=\"0\" max=\"100\" step=\"1\" value=\"100\">\n        <input type=\"range\" inline title=\"Line Active 2\" name=\"line1Active2\" min=\"0\" max=\"100\" step=\"1\" value=\"100\" condition=\"cardsAmount1 >1\">\n        <input type=\"range\" inline title=\"Line Active 3\" name=\"line1Active3\" min=\"0\" max=\"100\" step=\"1\" value=\"90\" condition=\"cardsAmount1 >2\">\n        <input type=\"range\" inline title=\"Line Active 4\" name=\"line1Active4\" min=\"0\" max=\"100\" step=\"1\" value=\"73\" condition=\"cardsAmount1 >3\">\n        <input type=\"range\" inline title=\"Line Active 5\" name=\"line1Active5\" min=\"0\" max=\"100\" step=\"1\" value=\"50\" condition=\"cardsAmount1 >4\">\n        <header condition=\"listCount >1\">Lines 2</header>\n        <input type=\"range\" inline title=\"Line Active 1\" name=\"line2Active1\" min=\"0\" max=\"100\" step=\"1\" value=\"94\" condition=\"listCount >1\">\n        <input type=\"range\" inline title=\"Line Active 2\" name=\"line2Active2\" min=\"0\" max=\"100\" step=\"1\" value=\"88\" condition=\"cardsAmount2 >1 &amp;&amp; listCount >1\">\n        <input type=\"range\" inline title=\"Line Active 3\" name=\"line2Active3\" min=\"0\" max=\"100\" step=\"1\" value=\"98\" condition=\"cardsAmount2 >2 &amp;&amp; listCount >1\">\n        <input type=\"range\" inline title=\"Line Active 4\" name=\"line2Active4\" min=\"0\" max=\"100\" step=\"1\" value=\"99\" condition=\"cardsAmount2 >3 &amp;&amp; listCount >1\">\n        <input type=\"range\" inline title=\"Line Active 5\" name=\"line2Active5\" min=\"0\" max=\"100\" step=\"1\" value=\"70\" condition=\"cardsAmount2 >4 &amp;&amp; listCount >1\">\n        <header>Lines Style</header>\n        <input type=\"color\" title=\"Lines Text Color\" name=\"linesTextColor\" value=\"#C4CFDE\">\n        <input type=\"color\" title=\"Lines BG\" name=\"linesBg\" value=\"#212428\">\n        <input type=\"color\" title=\"Lines Active BG 1\" name=\"linesBg1\" value=\"#6B67CE\">\n        <input type=\"color\" title=\"Lines Active BG 2\" name=\"linesBg2\" value=\"#FC636B\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\">\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#212428\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#212428\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\" mbr-if=\"showMainTitle || showMainSubtitle\">\n                <div class=\"mbr-section-head\">\n                    <h3 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showMainTitle\" data-app-selector=\".mbr-section-title\">\n                        9+ YEARS OF EXPERIENCE\n                    </h3>\n                    <h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showMainSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n                       <b>My Resume</b>\n                    </h5>\n                </div>\n            </div>\n        </div>\n        <div class=\"row card-row {{contentAlign}}\">\n            <div class=\"cards-container cards-container-1 col-12 col-md-6\">\n                <div class=\"cards-head\" mbr-if=\"showCardsTitle || showCardsSubtitle\">\n                    <h3 class=\"cards-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showCardsTitle\" data-app-selector=\".cards-title\">\n                        Features\n                    </h3>\n                    <h5 class=\"cards-subtitle mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" mbr-if=\"showCardsSubtitle\" data-app-selector=\".cards-subtitle\">\n                        <b>Salesforce Skills</b></h5>\n                </div>\n                <div class=\"cards-list\">\n                    <div class=\"lines-wrap\">\n                        <div class=\"line-item-container\">\n                            <p class=\"line-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showLinesText\" data-app-selector=\".line-text\">SALESFORCE ADMINISTRATION</p>\n                            <div class=\"line-item\">\n                                <div class=\"line-item-active line1-item-active-1\">\n                                    <span class=\"percent-text percent-text1\">%</span>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"line-item-container\" mbr-if=\"cardsAmount1 >1\">\n                            <p class=\"line-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showLinesText\" data-app-selector=\".line-text\">\n                                SALESFORCE CONSULTATION</p>\n                            <div class=\"line-item\">\n                                <div class=\"line-item-active line1-item-active-2\">\n                                    <span class=\"percent-text percent-text2\">%</span>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"line-item-container\" mbr-if=\"cardsAmount1 >2\">\n                            <p class=\"line-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showLinesText\" data-app-selector=\".line-text\">SALESFORCE SALES &amp; SERVICE CLOUD</p>\n                            <div class=\"line-item\">\n                                <div class=\"line-item-active line1-item-active-3\">\n                                    <span class=\"percent-text percent-text3\">%</span>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"line-item-container\" mbr-if=\"cardsAmount1 >3\">\n                            <p class=\"line-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showLinesText\" data-app-selector=\".line-text\">\n                                SALESFORCE HEALTH CLOUD</p>\n                            <div class=\"line-item\">\n                                <div class=\"line-item-active line1-item-active-4\">\n                                    <span class=\"percent-text percent-text4\">%</span>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"line-item-container\" mbr-if=\"cardsAmount1 >4\">\n                            <p class=\"line-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showLinesText\" data-app-selector=\".line-text\">\n                                SALESFORCE MARKETING CLOUD</p>\n                            <div class=\"line-item\">\n                                <div class=\"line-item-active line1-item-active-5\">\n                                    <span class=\"percent-text percent-text5\">%</span>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"cards-container cards-container-2 col-12 col-md-6\" mbr-if=\"listCount > 1\">\n                <div class=\"cards-head\" mbr-if=\"showCardsTitle || showCardsSubtitle\">\n                    <h3 class=\"cards-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showCardsTitle\" data-app-selector=\".cards-title\">\n                        Features\n                    </h3>\n                    <h5 class=\"cards-subtitle mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" mbr-if=\"showCardsSubtitle\" data-app-selector=\".cards-subtitle\">\n                        <b>Other Skills</b></h5>\n                </div>\n                <div class=\"cards-list\">\n                    <div class=\"lines-wrap\">\n                        <div class=\"line-item-container\">\n                            <p class=\"line-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showLinesText\" data-app-selector=\".line-text\">\n                                PROJECT MANAGEMENT</p>\n                            <div class=\"line-item\">\n                                <div class=\"line-item-active line2-item-active-1\">\n                                    <span class=\"percent-text percent-text1\">%</span>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"line-item-container\" mbr-if=\"cardsAmount2 >1\">\n                            <p class=\"line-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showLinesText\" data-app-selector=\".line-text\">\n                                RELEASE MANAGEMENT</p>\n                            <div class=\"line-item\">\n                                <div class=\"line-item-active line2-item-active-2\">\n                                    <span class=\"percent-text percent-text2\">%</span>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"line-item-container\" mbr-if=\"cardsAmount2 >2\">\n                            <p class=\"line-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showLinesText\" data-app-selector=\".line-text\">\n                                CUSTOMER SUCCESS</p>\n                            <div class=\"line-item\">\n                                <div class=\"line-item-active line2-item-active-3\">\n                                    <span class=\"percent-text percent-text3\">%</span>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"line-item-container\" mbr-if=\"cardsAmount2 >3\">\n                            <p class=\"line-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showLinesText\" data-app-selector=\".line-text\">\n                                PROCESS IMPROVEMENT</p>\n                            <div class=\"line-item\">\n                                <div class=\"line-item-active line2-item-active-4\">\n                                    <span class=\"percent-text percent-text4\">%</span>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"line-item-container\" mbr-if=\"cardsAmount2 >4\">\n                            <p class=\"line-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showLinesText\" data-app-selector=\".line-text\">\n                                LEADERSHIP</p>\n                            <div class=\"line-item\">\n                                <div class=\"line-item-active line2-item-active-5\">\n                                    <span class=\"percent-text percent-text5\">%</span>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n        </div>\n    </div>\n</section>",
