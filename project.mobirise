          "_name": "amenu1",
          "_sourceTheme": "expertm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"menu menu1 expertm5\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" always-top global once=\"menu\" not-draggable position-absolute>\n    <mbr-parameters>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Logo\" name=\"showLogo\">\n        <input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"3\" max=\"8\" step=\"0.1\" value=\"5\" condition=\"showLogo\">\n        <input type=\"checkbox\" title=\"Brand Name\" name=\"showBrand\">\n        <input type=\"checkbox\" title=\"Menu Items\" name=\"showItems\" checked>\n        <input type=\"checkbox\" title=\"Icons\" name=\"showIcons\" checked>\n        <select title=\"Amount\" name=\"iconsAmount\" condition=\"showIcons\">\n            <option value=\"1\" selected>1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n        </select>\n        <input type=\"color\" title=\"Icons Color\" name=\"iconsColor\" value=\"#FF014E\" condition=\"showIcons\">\n        <input type=\"checkbox\" title=\"Button\" name=\"showButtons\">\n        <header>Styles</header>\n        <input type=\"checkbox\" title=\"Sticky\" name=\"sticky\" checked>\n        <input type=\"checkbox\" title=\"Collapsed\" name=\"collapsed\">\n        <input type=\"checkbox\" title=\"Transparent\" name=\"transparent\" checked>\n        <input type=\"range\" title=\"Opacity\" name=\"opacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.9\" condition=\"transparent\">\n        <input type=\"color\" title=\"Color\" name=\"menuBgColor\" value=\"#212428\">\n        <input type=\"color\" title=\"Hamburger\" name=\"hamburgerColor\" value=\"#FF014E\">\n        <input type=\"color\" title=\"Hamburger BG 1\" name=\"hamburgerBg1\" value=\"#1e2024\">\n        <input type=\"color\" title=\"Hamburger BG 2\" name=\"hamburgerBg2\" value=\"#23272b\">\n        <input type=\"checkbox\" name=\"hamburgerShadow\" title=\"Hamburger Shadow\" checked>\n        <input type=\"color\" title=\"Shadow Color 1\" name=\"hamburgerColor1\" value=\"#191b1f\" condition=\"hamburgerShadow\">\n        <input type=\"color\" title=\"Shadow Color 2\" name=\"hamburgerColor2\" value=\"#23272B\" condition=\"hamburgerShadow\">\n    </mbr-parameters>\n    <nav class=\"navbar navbar-dropdown\" mbr-class=\"{'navbar-fixed-top':sticky,\n                    'navbar-expand-lg':!collapsed,\n                    'collapsed':collapsed}\">\n        <div class=\"container-fluid\">\n            <div class=\"navbar-brand\">\n                <span mbr-if=\"showLogo\" class=\"navbar-logo\">\n                    <a href=\"https://mobiri.se\">\n                        <img src=\"../_images/logo.png\" alt=\"Mobirise Website Builder\" mbr-style=\"{'height': logoSize + 'rem'}\">\n                    </a>\n                </span>\n                <span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove,-iconFont\"><a class=\"navbar-caption text-white\" data-app-selector=\".navbar-caption\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Dusty Hansen</a></span>\n            </div>\n            <button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\" mbr-if=\"showItems || showIcons || showButtons\">\n                <div class=\"hamburger\">\n                    <span></span>\n                    <span></span>\n                    <span></span>\n                    <span></span>\n                </div>\n            </button>\n            <div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\" mbr-if=\"showItems || showIcons || showButtons\">\n                <ul mbr-menu class=\"navbar-nav nav-dropdown\" mbr-theme-style=\"display-7\" mbr-if=\"showItems\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish && !showBrand && !showLogo}\"><li class=\"nav-item\">\n                        <a class=\"nav-link link text-white text-primary\" href=\"index.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">HOME</a>\n                    </li><li class=\"nav-item\"><a class=\"nav-link link text-white text-primary\" href=\"contact.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">CONTACT</a></li><li class=\"nav-item\"><a class=\"nav-link link text-white text-primary\" href=\"resume.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">RESUME</a></li></ul>\n                <div class=\"icons-menu\" mbr-if=\"showIcons\">\n                    <a class=\"iconfont-wrapper\" href=\"https://linkedin.com/in/dustyhansen\" target=\"_blank\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-linkedin socicon\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 1\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-twitter socicon\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 2\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-instagram socicon\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 3\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-linkedin socicon\"></span>\n                    </a>\n                </div>\n                <div mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-7\" class=\"navbar-buttons mbr-section-btn custom-section-btn\">\n                    <a class=\"btn btn-black\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                        PURCHASE NOW</a>\n                </div>\n            </div>\n        </div>\n    </nav>\n</section>",
          "_cid": "uUI83Hfxg3",
          "_anchor": "amenu1-4",
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)",
              "background-attachment": "fixed",
              "background-repeat": "no-repeat",
              "background-size": "cover",
              "background-position": "center center"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "overflow": "hidden",
            ".card-row": {
              "align-items": "stretch"
            },
            ".item-wrap": {
              "position": "relative",
              "width": "100%",
              "padding": "20px",
              "& when (@showImg)": {
                "margin-top": "60px"
              },
              "border-radius": "10px",
              "background": "linear-gradient(145deg, @cardBg1, @cardBg2)",
              "& when (@cardShadow)": {
                "box-shadow": "10px 10px 19px @shadowColor1, -10px -10px 19px @shadowColor2"
              }
            },
            ".item-left-item": {
              "display": "flex",
              "align-items": "flex-start",
              "width": "100%",
              "& when (@showBorder)": {
                "border-right": "1px solid @borderColor"
              },
              "@media (max-width: 1199px)": {
                "flex-direction": "column",
                "align-items": "center"
              },
              "@media (max-width: 991px)": {
                "padding-bottom": "20px",
                "border-right": "none",
                "& when (@showBorder)": {
                  "border-bottom": "1px solid @borderColor"
                }
              }
            },
            ".image-wrapper": {
              "margin-right": "30px",
              "img": {
                "border-radius": "15px",
                "max-width": "200px",
                "aspect-ratio": "(1 / 1)",
                "width": "200px",
                "& when (@showImgBorder)": {
                  "border": "5px solid @borderImgColor"
                },
                "position": "relative",
                "top": "-80px",
                "object-fit": "cover"
              },
              "@media (max-width: 1199px)": {
                "margin-right": "0"
              }
            },
            ".text-left-wrap": {
              "@media (max-width: 1199px)": {
                "& when (@showImg)": {
                  "margin-top": "-46px"
                }
              }
            },
            ".mbr-section-title": {
              "color": "#C4CFDE",
              "margin-bottom": "10px",
              "@media (max-width: 1199px)": {
                "text-align": "center !important"
              }
            },
            ".mbr-section-subtitle": {
              "color": "#878e99",
              "margin-bottom": "0",
              "@media (max-width: 1199px)": {
                "text-align": "center !important"
              }
            },
            ".social-container": {
              "width": "100%",
              "padding-top": "35px",
              "@media (max-width: 1199px)": {
                "padding-top": "25px"
              }
            },
            ".social-title": {
              "color": "#C4CFDE",
              "margin-bottom": "15px",
              "@media (max-width: 1199px)": {
                "text-align": "center !important"
              }
            },
            ".social-list": {
              "display": "flex",
              "align-items": "center",
              "flex-wrap": "wrap",
              "margin": "-7px",
              "@media (max-width: 1199px)": {
                "justify-content": "center !important"
              }
            },
            ".soc-item": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "position": "relative",
              "margin": "7px",
              "min-width": "53px",
              "padding": "10px",
              "aspect-ratio": "(1 / 1)",
              "border-radius": "6px",
              "background": "linear-gradient(145deg, @socialBgColor1, @socialBgColor2)",
              "& when (@socialShadow)": {
                "box-shadow": "10px 10px 19px @socialShadow1, -10px -10px 19px @socialShadow2"
              },
              "transition": "0.4s all",
              "&:before": {
                "content": "\"\"",
                "position": "absolute",
                "top": "0",
                "left": "0",
                "z-index": "4",
                "transition": "0.4s all",
                "width": "100%",
                "height": "100%",
                "border-radius": "5px",
                "background": "linear-gradient(to right bottom, #212428, #16181c)",
                "opacity": "0"
              },
              ".mbr-iconfont": {
                "position": "relative",
                "z-index": "5",
                "transition": "0.4s all",
                "font-size": "20px",
                "color": "@socialColor"
              },
              "&:hover": {
                "transform": "translateY(-3px)",
                "&:before": {
                  "opacity": "1"
                }
              }
            },
            ".item-right-item": {
              "display": "flex",
              "align-items": "flex-start",
              "width": "100%",
              "@media (max-width: 991px)": {
                "padding-top": "10px",
                "margin": "0 -20px -20px"
              },
              "@media (max-width: 575px)": {
                "flex-wrap": "wrap",
                "margin": "0"
              }
            },
            ".contacts-container": {
              "max-width": "50%",
              "padding-left": "30px",
              "margin": "16px 0",
              "@media (max-width: 991px)": {
                "padding": "20px"
              },
              "&:nth-child(2)": {
                "@media (max-width: 991px)": {
                  "padding-left": "100px"
                },
                "@media (max-width: 767px)": {
                  "padding-left": "0"
                },
                "@media (max-width: 575px)": {
                  "padding-left": "20px"
                }
              },
              "@media (max-width: 575px)": {
                "max-width": "100%",
                "width": "100%",
                "text-align": "center !important",
                "margin": "0",
                "padding": "0 !important"
              }
            },
            ".contact-item": {
              "padding": "10px 0 20px"
            },
            ".card-title": {
              "color": "#878e99",
              "margin-bottom": "4px"
            },
            ".card-text": {
              "color": "#C4CFDE",
              "margin-bottom": "0"
            }
          },
          "_name": "acontact1",
          "_sourceTheme": "expertm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"contact expertm5\" group=\"Contact\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"10\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n        <select title=\"Align\" name=\"contentAlign\">\n            <option value=\"justify-content-start\">Left</option>\n            <option value=\"justify-content-center\" selected>Center</option>\n            <option value=\"justify-content-end\">Right</option>\n        </select>\n        <input type=\"range\" inline title=\"Content Width\" name=\"contentWidth\" min=\"6\" max=\"12\" step=\"1\" value=\"12\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Image\" name=\"showImg\" checked>\n        <input type=\"checkbox\" title=\"Image Border\" name=\"showImgBorder\" checked condition=\"showImg\">\n        <input type=\"color\" title=\"Image Border Color\" name=\"borderImgColor\" value=\"#1e2024\" condition=\"showImgBorder && showImg\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Border\" name=\"showBorder\" checked>\n        <input type=\"color\" title=\"Border Color\" name=\"borderColor\" value=\"#16181c\" condition=\"showBorder\">\n        <input type=\"range\" inline title=\"Contacts Count\" name=\"contactsCount\" min=\"0\" max=\"4\" step=\"1\" value=\"4\">\n        <input type=\"checkbox\" title=\"Contacts Title\" name=\"showCardTitle\" checked condition=\"contactsCount >0\">\n        <input type=\"checkbox\" title=\"Contacts Text\" name=\"showCardSubtitle\" checked condition=\"contactsCount >0\">\n        <input type=\"checkbox\" title=\"Social\" name=\"showSocial\">\n        <header condition=\"showSocial\">Social</header>\n        <input type=\"checkbox\" title=\"Social Title\" name=\"showSocialTitle\" condition=\"showSocial\">\n        <input type=\"color\" title=\"Social Color\" name=\"socialColor\" value=\"#C4CFDE\" condition=\"showSocial\">\n        <input type=\"color\" title=\"Social BG Color 1\" name=\"socialBgColor1\" value=\"#1e2024\" condition=\"showSocial\">\n        <input type=\"color\" title=\"Social BG Color 2\" name=\"socialBgColor2\" value=\"#23272b\" condition=\"showSocial\">\n        <input type=\"checkbox\" name=\"socialShadow\" title=\"Social Shadow\" condition=\"showSocial\" checked>\n        <input type=\"color\" title=\"Shadow Color 1\" name=\"socialShadow1\" value=\"#191b1f\" condition=\"socialShadow && showSocial\">\n        <input type=\"color\" title=\"Shadow Color 2\" name=\"socialShadow2\" value=\"#23272B\" condition=\"socialShadow && showSocial\">\n        <input type=\"range\" name=\"socialCount\" title=\"Social Count\" min=\"1\" max=\"6\" step=\"1\" value=\"3\" condition=\"showSocial\">\n        <header>Card Style</header>\n        <input type=\"color\" title=\"Card BG 1\" name=\"cardBg1\" value=\"#1e2024\">\n        <input type=\"color\" title=\"Card BG 2\" name=\"cardBg2\" value=\"#23272b\">\n        <input type=\"checkbox\" name=\"cardShadow\" title=\"Card Shadow\" checked>\n        <input type=\"color\" title=\"Shadow Color 1\" name=\"shadowColor1\" value=\"#191b1f\" condition=\"cardShadow\">\n        <input type=\"color\" title=\"Shadow Color 2\" name=\"shadowColor2\" value=\"#23272B\" condition=\"cardShadow\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\">\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#212428\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#212428\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div class=\"container\">\n        <div class=\"row card-row {{contentAlign}}\">\n            <div class=\"item-card col-12 d-flex col-lg-{{contentWidth}}\">\n                <div class=\"item-wrap\">\n                    <div class=\"row m-0 align-items-start\">\n                        <div class=\"col-12 col-lg-6 flex-grow-1\" mbr-if=\"showImg || showTitle || showSubtitle || showSocial\">\n                            <div class=\"item-left-item\">\n                                <div class=\"image-wrapper\" mbr-if=\"showImg\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/2023-380x380.png\" alt=\"Dusty Hansen\">\n                                </div>\n                                <div class=\"text-left-wrap\">\n                                    <h5 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">\n                                       <b>Dusty Hansen</b></h5>\n                                    <h5 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n                                        Salesforce Expert</h5>\n                                    <div class=\"social-container\" mbr-if=\"showSocial\">\n                                        <p class=\"social-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showSocialTitle\" data-app-selector=\".social-title\">\n                                            FIND WITH ME\n                                        </p>\n                                        <div class=\"social-list\">\n                                            <div class=\"soc-item\" mbr-if=\"socialCount>0\">\n                                                <span mbr-icon class=\"socicon-twitter socicon mbr-iconfont mbr-iconfont-social\"></span>\n                                            </div>\n                                            <div class=\"soc-item\" mbr-if=\"socialCount>1\">\n                                                <span mbr-icon class=\"socicon-facebook socicon mbr-iconfont mbr-iconfont-social\"></span>\n                                            </div>\n                                            <div class=\"soc-item\" mbr-if=\"socialCount>2\">\n                                                <span mbr-icon class=\"socicon-instagram socicon mbr-iconfont mbr-iconfont-social\"></span>\n                                            </div>\n                                            <div class=\"soc-item\" mbr-if=\"socialCount>3\">\n                                                <span mbr-icon class=\"socicon-youtube socicon mbr-iconfont mbr-iconfont-social\"></span>\n                                            </div>\n                                            <div class=\"soc-item\" mbr-if=\"socialCount>4\">\n                                                <span mbr-icon class=\"socicon-behance socicon mbr-iconfont mbr-iconfont-social\"></span>\n                                            </div>\n                                            <div class=\"soc-item\" mbr-if=\"socialCount>5\">\n                                                <span mbr-icon class=\"socicon-vimeo socicon mbr-iconfont mbr-iconfont-social\"></span>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n\n                        </div>\n                        <div class=\"col-12 col-lg-6 flex-grow-1 align-self-center\" mbr-if=\"contactsCount >0 &amp;&amp; (showCardTitle || showCardSubtitle)\">\n                            <div class=\"item-right-item\">\n                                <div class=\"contacts-container\">\n                                    <div class=\"contact-item\">\n                                        <p class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">\n                                            EMAIL\n                                        </p>\n                                        <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardSubtitle\" data-app-selector=\".card-text\">\n                                           <b>dusty@hansen.me</b></p>\n                                    </div>\n                                    <div class=\"contact-item\" mbr-if=\"contactsCount >1\">\n                                        <p class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">\n                                            BIRTHDAY\n\n                                        </p>\n                                        <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardSubtitle\" data-app-selector=\".card-text\">\n                                            <b>13 September</b></p>\n                                    </div>\n                                </div>\n                                <div class=\"contacts-container\" mbr-if=\"contactsCount >2\">\n                                    <div class=\"contact-item\" mbr-if=\"contactsCount >2\">\n                                        <p class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">\n                                            PHONE\n\n                                        </p>\n                                        <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardSubtitle\" data-app-selector=\".card-text\">\n                                            <b>(815) 258-8298</b></p>\n                                    </div>\n                                    <div class=\"contact-item\" mbr-if=\"contactsCount >3\">\n                                        <p class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title\">\n                                            LOCATION\n\n                                        </p>\n                                        <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardSubtitle\" data-app-selector=\".card-text\">\n                                            <b>Chicago Metro</b></p>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "uUItxUiB3E",
