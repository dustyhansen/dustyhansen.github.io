                "justify-content": "left"
              },
              ".navbar-buttons": {
                "margin-top": "20px",
                "text-align": "left",
                "margin-left": "-0.6rem",
                "margin-right": "-0.6rem"
              }
            },
            "@media (max-width: 991px)": {
              ".container-fluid": {
                "flex-wrap": "wrap"
              },
              "button.navbar-toggler": {
                "display": "flex"
              },
              ".navbar-brand": {
